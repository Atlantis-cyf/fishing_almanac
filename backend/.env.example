# Copy to .env and fill in values.

PORT=8080

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

CATCH_IMAGE_FIELD=image
STORE_IMAGE_BASE64=true

# Supabase Storage bucket names
CATCH_IMAGE_BUCKET=catch-images
SPECIES_IMAGE_BUCKET=species-images

# Species admin panel permission control
# Comma-separated list, e.g. admin1@example.com,admin2@example.com
ADMIN_EMAILS=
# Optional: comma-separated user UUIDs
ADMIN_USER_IDS=

# One-time: run `npm run migrate:analytics` to create public.analytics_events.
# Option A — full URI from Supabase Dashboard → Settings → Database → Connection string → URI
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# Option B — only the database password (same as Dashboard → Database password)
# SUPABASE_DB_PASSWORD=

# 豆包（Doubao）鱼种识别 — 火山方舟 ARK 平台
# 获取方式: https://console.volcengine.com/ark → API Key 管理
DOUBAO_API_KEY=
# 须与方舟「API 里填的 model」一致：小写 + 连字符，如 doubao-seed-1-6-vision-250815；
# 不要用控制台展示名 Doubao-Seed-1.6-vision（1.6 与大小写会导致 404 NotFound）。
# 或填推理接入点 ID：ep-xxxxxx
DOUBAO_MODEL_ID=
